# ============================================================
# INVENTARIO BACKEND - Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env a control de versiones.
# ============================================================

# Puerto del servidor (default: 3000)
PORT=3000

# MongoDB Atlas connection string
# Formato: mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/inventory

# JWT Secret - usa un string aleatorio de al menos 32 caracteres
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_ALEATORIO_DE_32_CHARS

# Cloudinary - copia la URL completa desde tu dashboard de Cloudinary
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Entorno (development | production)
NODE_ENV=development

# Origins permitidos por CORS (separados por coma si son varios)
# Desarrollo: http://localhost:5173
# Producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:5173
